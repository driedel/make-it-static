# =====================================================
# Make it Static — environment variables
# Copy to .env and adjust as needed.
# =====================================================

# HMAC secret shared with clients (any HTTP client, CMS plugin, CI/CD, etc.).
# In production, generate with: openssl rand -hex 32
HMAC_SECRET=your-app-secret-key

# Timestamp tolerance (seconds) to prevent replay attacks
HMAC_MAX_SKEW=300

# Redis
REDIS_URL=redis://redis:6379/0

# ---- AWS / S3 ----
# DEV: points to local MinIO. AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are also
# used as MinIO root credentials — change them from the defaults before exposing MinIO.
# PROD: leave S3_ENDPOINT_URL empty and S3_USE_PATH_STYLE=false.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=nome-do-bucket
S3_ENDPOINT_URL=http://minio:9000
S3_USE_PATH_STYLE=true

# ---- CloudFront ----
# Global fallback for cache invalidation. Can be overridden per-request via
# cloudfront_distribution_id in the POST /publish payload — useful when multiple
# sites share the same bucket but have separate CloudFront distributions.
# DEV: leave empty to skip invalidation.
CLOUDFRONT_DISTRIBUTION_ID=

# ---- Local preview (nginx) ----
# Used ONLY by the local nginx preview (docker-compose.yml).
# The worker derives the hostname directly from the URL in each request payload —
# it does not use this variable. Set it to whichever site you want to preview locally.
# In production each CloudFront points to the bucket with Origin Path = "/{hostname}".
ORIGIN_HOST=www.yoursite.com

# Internal hosts that may appear in scraped HTML when running via Docker network.
# Postprocess replaces them with relative paths, just like the external host.
# Remove or leave empty in production.
SCRAPE_INTERNAL_HOSTS=localhost:8080,site_nginx
